# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this to your Gemini API key from Google AI Studio or Google Cloud Vertex AI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints. (e.g., https://your-domain.com for production)
APP_URL="MY_APP_URL"

# Whatsapp Integration Secrets
WHATSAPP_TOKEN="YOUR_WHATSAPP_CLOUD_API_TOKEN"
WHATSAPP_PHONE_NUMBER_ID="YOUR_WHATSAPP_PHONE_NUMBER_ID"
WEBHOOK_VERIFY_TOKEN="YOUR_RANDOM_VERIFY_TOKEN"

# Firebase Admin configuration
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", "project_id": "..."}'
